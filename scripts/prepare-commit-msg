#!/usr/bin/env bash
# prepare-commit-msg --- Append AI-Model trailer for AI-assisted commits.
#
# Prerequisites (must be set by AI harness before invoking git commit):
#   AI_COMMIT=1              — enables AI attribution
#   AI_MODEL                 — e.g., "DeepSeek V4 Flash (Max)"
#   GIT_COMMITTER_NAME       — e.g., "OhMyOpenAgent" (the harness)
#   GIT_COMMITTER_EMAIL      — e.g., "ohmyopenagent@local"
#
# For --amend and rebase: skips if trailer already present (no dupes).

set -euo pipefail

COMMIT_MSG_FILE="${1:-}"

# ── Exit early if not AI-driven ──────────────────────────────────────────
if [ "${AI_COMMIT:-0}" != "1" ]; then
  exit 0
fi

model="${AI_MODEL:-}"
harness="${GIT_COMMITTER_NAME:-}"
if [ -z "$model" ]; then
  echo "WARNING: AI_COMMIT=1 but AI_MODEL empty — skipping" >&2
  exit 0
fi

# ── Warn if committer env vars not set ───────────────────────────────────
if [ -z "${GIT_COMMITTER_EMAIL:-}" ] || [ -z "${harness}" ]; then
  echo "WARNING: AI_COMMIT=1 but GIT_COMMITTER_NAME or GIT_COMMITTER_EMAIL not set — committer will not be overridden" >&2
fi

# ── Skip if AI-Model trailer already exists (--amend, rebase replay) ─────
if grep -q "^AI-Model:" "$COMMIT_MSG_FILE" 2>/dev/null; then
  exit 0
fi

# ── Append AI-Model trailer ──────────────────────────────────────────────
last_line="$(tail -1 "$COMMIT_MSG_FILE" 2>/dev/null || true)"
[ -n "$last_line" ] && echo "" >> "$COMMIT_MSG_FILE"
echo "AI-Model: ${model}" >> "$COMMIT_MSG_FILE"
